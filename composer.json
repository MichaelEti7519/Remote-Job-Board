{
    "name": "remote/job-board-api",
    "description": "Remote Job Board Employer Hiring Flow API",
    "type": "project",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.9",
        "laravel/pint": "^1.13",
        "nunomaduro/collision": "^8.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump"
        ]
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}